{
  "name": "slaif-connect-relay-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:extension": "./scripts/build-extension.sh",
    "check:vendor": "node scripts/check-vendor.mjs",
    "check:js": "node scripts/checks/check-js.mjs",
    "check:json": "node scripts/checks/check-json.mjs",
    "test": "npm run check:json && npm run check:js && npm run check:vendor && npm run test:policy && node tests/policy.test.mjs && node tests/session_descriptor.test.mjs && node tests/job_output_parser.test.mjs && node tests/ssh_client_args.test.mjs && node tests/relay_adapter.test.mjs && npm run test:relay",
    "plugin:install": "./scripts/install-plugin.sh",
    "plugin:verify": "node scripts/verify-plugin.js",
    "dev:extension-stack": "node tools/start-extension-dev-stack.mjs",
    "browser:install": "playwright install chromium",
    "test:browser": "playwright test",
    "test:browser:launch-flow": "playwright test tests/browser/extension-launch-flow.spec.mjs",
    "test:browser:signed-policy": "playwright test tests/browser/extension-signed-policy.spec.mjs",
    "test:browser:headed": "SLAIF_BROWSER_HEADED=1 playwright test --headed",
    "test:browser:debug": "SLAIF_BROWSER_HEADED=1 PWDEBUG=1 playwright test --headed --timeout=0",
    "test:browser:hostkey-negative": "playwright test -g \"rejects a changed host key\"",
    "test:relay": "node tests/relay/relay-auth.test.mjs",
    "test:relay:e2e": "node tests/relay/e2e-relay-ssh.mjs",
    "policy:keygen:dev": "node scripts/policy/generate-dev-policy-keypair.mjs",
    "policy:sign": "node scripts/policy/sign-hpc-policy.mjs",
    "policy:verify": "node scripts/policy/verify-hpc-policy.mjs",
    "test:policy": "node tests/policy/canonical-json.test.mjs && node tests/policy/policy-signature.test.mjs && node tests/policy/policy-validation.test.mjs && node tests/policy/policy-rollback.test.mjs",
    "upstream:init": "./scripts/init-upstream.sh",
    "vendor:libapps": "./scripts/vendor-libapps.sh",
    "start:relay": "npm --prefix server/relay start"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
