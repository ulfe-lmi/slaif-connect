#!/bin/sh
set -eu

VERSION="slaif-launch reference 0.1.0"
SESSION_ID=""
SCHEDULER="${SLAIF_SCHEDULER:-slurm}"
API_BASE="${SLAIF_API_BASE:-}"
DRY_RUN=0
VERBOSE=0
INTENT_FILE=""
PROFILE_FILE=""
WORK_DIR="${SLAIF_LAUNCHER_WORK_DIR:-${HOME:-}/.slaif-connect/launcher}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
TEMPLATE_DIR="${SLAIF_LAUNCHER_TEMPLATE_DIR:-$SCRIPT_DIR/templates}"
INTENT_HELPER="${SLAIF_LAUNCHER_INTENT_HELPER:-$SCRIPT_DIR/lib/launcher-intent.py}"
WAIT_RESULT=0
RESULT_TIMEOUT_SECONDS="${SLAIF_LAUNCHER_RESULT_TIMEOUT_SECONDS:-10}"
MAX_OUTPUT_BYTES="${SLAIF_LAUNCHER_MAX_OUTPUT_BYTES:-65536}"

usage() {
  cat <<'EOF'
Usage: slaif-launch --session <SESSION_ID> [--scheduler slurm] [--dry-run] [--verbose]
       slaif-launch --session <SESSION_ID> --intent-file <PATH> --profile-file <PATH> [--work-dir <PATH>] [--dry-run] [--wait-result]

Runs a site-approved SLAIF launcher flow under the authenticated HPC user.
This reference launcher does not accept arbitrary commands, job scripts,
SSH credentials, tokens, passwords, OTPs, or private keys.
EOF
}

fail() {
  code="$1"
  shift
  printf '%s\n' "$*" >&2
  exit "$code"
}

validate_session_id() {
  session="$1"
  printf '%s\n' "$session" | grep -Eq '^sess_[A-Za-z0-9_-]{8,128}$'
}

validate_script_path() {
  script_path="$1"
  case "$script_path" in
    /*) ;;
    *) return 1 ;;
  esac
  printf '%s\n' "$script_path" | grep -Eq '^[A-Za-z0-9_./:+-]+$' || return 1
  case "$script_path" in
    *..*) return 1 ;;
  esac
  return 0
}

validate_input_path() {
  input_path="$1"
  [ -n "$input_path" ] || return 1
  case "$input_path" in
    -*|*..*|*\'*|*\"*|*' '*|*';'*|*'`'*|*'$'*|*'|'*|*'&'*) return 1 ;;
  esac
  [ -f "$input_path" ] || return 1
  return 0
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --session)
      [ "$#" -ge 2 ] || fail 2 "missing value for --session"
      SESSION_ID="$2"
      shift 2
      ;;
    --scheduler)
      [ "$#" -ge 2 ] || fail 2 "missing value for --scheduler"
      SCHEDULER="$2"
      shift 2
      ;;
    --api-base)
      [ "$#" -ge 2 ] || fail 2 "missing value for --api-base"
      API_BASE="$2"
      shift 2
      ;;
    --intent-file)
      [ "$#" -ge 2 ] || fail 2 "missing value for --intent-file"
      INTENT_FILE="$2"
      shift 2
      ;;
    --profile-file)
      [ "$#" -ge 2 ] || fail 2 "missing value for --profile-file"
      PROFILE_FILE="$2"
      shift 2
      ;;
    --work-dir)
      [ "$#" -ge 2 ] || fail 2 "missing value for --work-dir"
      WORK_DIR="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --wait-result)
      WAIT_RESULT=1
      shift
      ;;
    --result-timeout-seconds)
      [ "$#" -ge 2 ] || fail 2 "missing value for --result-timeout-seconds"
      RESULT_TIMEOUT_SECONDS="$2"
      shift 2
      ;;
    --max-output-bytes)
      [ "$#" -ge 2 ] || fail 2 "missing value for --max-output-bytes"
      MAX_OUTPUT_BYTES="$2"
      shift 2
      ;;
    --verbose)
      VERBOSE=1
      shift
      ;;
    --version)
      printf '%s\n' "$VERSION"
      exit 0
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail 2 "unknown flag: $1"
      ;;
  esac
done

[ -n "$SESSION_ID" ] || fail 2 "--session is required"
if ! validate_session_id "$SESSION_ID"; then
  fail 3 "invalid SLAIF session id"
fi

case "$SCHEDULER" in
  slurm) ;;
  *) fail 2 "unsupported scheduler: $SCHEDULER" ;;
esac

if [ -n "$INTENT_FILE" ] || [ -n "$PROFILE_FILE" ]; then
  [ -n "$INTENT_FILE" ] || fail 2 "--intent-file is required with --profile-file"
  [ -n "$PROFILE_FILE" ] || fail 2 "--profile-file is required with --intent-file"
  validate_input_path "$INTENT_FILE" || fail 4 "--intent-file must be an existing safe file path"
  validate_input_path "$PROFILE_FILE" || fail 4 "--profile-file must be an existing safe file path"
  command -v python3 >/dev/null 2>&1 || fail 4 "python3 is required for launcher intent mode"
  [ -f "$INTENT_HELPER" ] || fail 4 "launcher intent helper is missing"
  [ -d "$TEMPLATE_DIR" ] || fail 4 "launcher template directory is missing"
  if [ "$DRY_RUN" -eq 1 ]; then
    exec python3 "$INTENT_HELPER" \
      --session "$SESSION_ID" \
      --intent-file "$INTENT_FILE" \
      --profile-file "$PROFILE_FILE" \
      --work-dir "$WORK_DIR" \
      --template-dir "$TEMPLATE_DIR" \
      --dry-run
  fi
  set -- python3 "$INTENT_HELPER" \
    --session "$SESSION_ID" \
    --intent-file "$INTENT_FILE" \
    --profile-file "$PROFILE_FILE" \
    --work-dir "$WORK_DIR" \
    --template-dir "$TEMPLATE_DIR" \
    --result-timeout-seconds "$RESULT_TIMEOUT_SECONDS" \
    --max-output-bytes "$MAX_OUTPUT_BYTES"
  if [ "$WAIT_RESULT" -eq 1 ]; then
    set -- "$@" --wait-result
  fi
  exec "$@"
fi

if [ -n "$API_BASE" ] && [ "$VERBOSE" -eq 1 ]; then
  printf 'Using SLAIF API base configured by site policy\n' >&2
fi

if [ "$DRY_RUN" -eq 1 ] || [ -n "${SLAIF_LAUNCHER_TEST_JOB_ID:-}" ]; then
  job_id="${SLAIF_LAUNCHER_TEST_JOB_ID:-424242}"
  printf '%s\n' "$job_id" | grep -Eq '^[0-9]+$' || fail 4 "invalid SLAIF_LAUNCHER_TEST_JOB_ID"
  printf 'Submitted batch job %s\n' "$job_id"
  exit 0
fi

[ -n "${SLAIF_SLURM_SCRIPT:-}" ] || fail 4 "SLAIF_SLURM_SCRIPT is required for real SLURM mode"
validate_script_path "$SLAIF_SLURM_SCRIPT" || fail 4 "SLAIF_SLURM_SCRIPT must be an absolute safe site-owned path"
command -v sbatch >/dev/null 2>&1 || fail 4 "sbatch not found"

export SLAIF_SESSION_ID="$SESSION_ID"
if ! sbatch "$SLAIF_SLURM_SCRIPT"; then
  fail 5 "scheduler submission failed"
fi
