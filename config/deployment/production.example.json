{
  "env": "production",
  "apiBaseUrl": "https://connect.slaif.si",
  "relayPublicUrl": "wss://connect.slaif.si/ssh-relay",
  "allowedWebOrigins": [
    "https://connect.slaif.si",
    "https://stare.lmi.link"
  ],
  "allowedRelayTargetsFile": "/etc/slaif/allowed-relay-targets.json",
  "tokenStore": "redis",
  "tokenStoreUrl": "rediss://TOKEN_STORE_HOST:6379/0",
  "redisKeyPrefix": "slaif",
  "redisConnectTimeoutMs": 10000,
  "redisCommandTimeoutMs": 10000,
  "redisTlsEnabled": true,
  "auditLogMode": "external",
  "auditIncludeSessionId": false,
  "metricsMode": "prometheus",
  "metricsPath": "/metrics",
  "healthPath": "/healthz",
  "readyPath": "/readyz",
  "metricsIncludeHpcLabel": false,
  "observabilityEnvLabel": "production",
  "relayMaxAuthBytes": 4096,
  "relayUnauthTimeoutMs": 10000,
  "relayIdleTimeoutMs": 300000,
  "relayAbsoluteTimeoutMs": 3600000,
  "jobReportMaxBytes": 16384,
  "rateLimitMode": "external",
  "policyTrustRootsFile": "/etc/slaif/policy-trust-roots.json",
  "signedPolicyFile": "/etc/slaif/hpc-policy.signed.json"
}
