{
  "version": 1,
  "description": "Example SLAIF Connect HPC policy. Replace host keys before production use.",
  "relay": {
    "url": "wss://connect.slaif.si/ssh-relay",
    "sessionDescriptorUrlTemplate": "https://connect.slaif.si/api/connect/session/${SESSION_ID}"
  },
  "allowedPayloads": {
    "gpu_diagnostics_v1": {
      "type": "fast_diagnostic",
      "scheduler": "slurm",
      "requiresGpu": true,
      "maxRuntimeSeconds": 300,
      "maxOutputBytes": 65536,
      "resultSchema": "slaif.gpuDiagnosticsResult.v1"
    },
    "cpu_memory_diagnostics_v1": {
      "type": "fast_diagnostic",
      "scheduler": "slurm",
      "requiresGpu": false,
      "maxRuntimeSeconds": 300,
      "maxOutputBytes": 65536,
      "resultSchema": "slaif.cpuMemoryDiagnosticsResult.v1"
    },
    "gams_chat_v1": {
      "type": "interactive_llm",
      "scheduler": "slurm",
      "model": "cjvt/GaMS3-12B-Instruct",
      "runtime": "vllm",
      "requiresGpu": true,
      "requiresOutboundWorkloadConnection": true,
      "maxSessionSeconds": 3600,
      "idleTimeoutSeconds": 300,
      "maxPromptBytes": 16000,
      "maxOutputTokens": 1024
    }
  },
  "hosts": {
    "stare": {
      "displayName": "LMI STARE host",
      "sshHost": "stare.lmi.link",
      "sshPort": 22,
      "hostKeyAlias": "stare",
      "knownHosts": [
        "# TODO replace with real SSH host key: stare ssh-ed25519 AAAA..."
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "gpu_diagnostics_v1",
        "cpu_memory_diagnostics_v1"
      ],
      "allowInteractiveTerminal": false
    },
    "arneshpc": {
      "displayName": "ARNES HPC",
      "sshHost": "hpc-login.arnes.si",
      "sshPort": 22,
      "hostKeyAlias": "arneshpc",
      "knownHosts": [
        "# TODO replace with real SSH host key: arneshpc ssh-ed25519 AAAA..."
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "gpu_diagnostics_v1",
        "cpu_memory_diagnostics_v1",
        "gams_chat_v1"
      ],
      "allowInteractiveTerminal": false
    },
    "vegahpc": {
      "displayName": "Vega HPC login",
      "sshHost": "login.vega.izum.si",
      "sshPort": 22,
      "hostKeyAlias": "vegahpc",
      "knownHosts": [
        "# TODO replace with real SSH host key or host certificate CA entry"
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "gpu_diagnostics_v1",
        "cpu_memory_diagnostics_v1",
        "gams_chat_v1"
      ],
      "allowInteractiveTerminal": false
    },
    "vegahpccpu": {
      "displayName": "Vega HPC CPU login",
      "sshHost": "logincpu.vega.izum.si",
      "sshPort": 22,
      "hostKeyAlias": "vegahpccpu",
      "knownHosts": [
        "# TODO replace with real SSH host key or host certificate CA entry"
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "cpu_memory_diagnostics_v1"
      ],
      "allowInteractiveTerminal": false
    },
    "vegahpcgpu": {
      "displayName": "Vega HPC GPU login",
      "sshHost": "gpulogingpu.vega.izum.si",
      "sshPort": 22,
      "hostKeyAlias": "vegahpcgpu",
      "knownHosts": [
        "# TODO replace with real SSH host key or host certificate CA entry"
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "gpu_diagnostics_v1",
        "gams_chat_v1"
      ],
      "allowInteractiveTerminal": false
    },
    "test-sshd": {
      "displayName": "Local development test sshd",
      "sshHost": "127.0.0.1",
      "sshPort": 22,
      "hostKeyAlias": "test-sshd",
      "knownHosts": [
        "# DEVELOPMENT ONLY. tools/start-extension-dev-stack.mjs writes a real generated known_hosts entry into build/extension/config/dev_runtime.local.json.",
        "test-sshd ssh-ed25519 AAAAplaceholder"
      ],
      "remoteCommandTemplate": "/opt/slaif/bin/slaif-launch --session ${SESSION_ID}",
      "allowedPayloadIds": [
        "gpu_diagnostics_v1"
      ],
      "allowInteractiveTerminal": false,
      "developmentOnly": true
    }
  }
}
